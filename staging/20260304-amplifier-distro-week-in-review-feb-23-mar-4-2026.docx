<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>amplifier-distro: Week in Review — Feb 23 – Mar 4, 2026</title>
    <style>
        :root {
            --accent: #6366F1;
            --accent-glow: rgba(99, 102, 241, 0.15);
            --accent-dim: rgba(99, 102, 241, 0.6);

            --surface-1: rgba(255,255,255,0.06);
            --surface-2: rgba(255,255,255,0.10);
            --surface-3: rgba(255,255,255,0.15);
            --border-subtle: rgba(255,255,255,0.12);
            --border-visible: rgba(255,255,255,0.20);

            --text-primary: #ffffff;
            --text-secondary: rgba(255,255,255,0.7);
            --text-tertiary: rgba(255,255,255,0.5);

            --font-headline: clamp(36px, 6vw, 64px);
            --font-medium-headline: clamp(24px, 4.5vw, 44px);
            --font-subhead: clamp(16px, 2.8vw, 28px);
            --font-body: clamp(14px, 2vw, 18px);
            --font-small: clamp(12px, 1.8vw, 15px);
            --font-label: clamp(11px, 1.4vw, 13px);

            --padding-slide: clamp(40px, 8vw, 100px);
            --padding-slide-top: clamp(60px, 10vw, 120px);
            --padding-slide-bottom: clamp(80px, 12vw, 100px);
            --gap-grid: clamp(16px, 2.5vw, 28px);
            --radius: clamp(12px, 2vw, 16px);
            --radius-sm: clamp(8px, 1vw, 12px);
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', Roboto, sans-serif;
            background: #000;
            color: var(--text-primary);
            overflow: hidden;
            overscroll-behavior: none;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* ── Slides ── */
        .slide {
            display: none;
            width: 100vw;
            min-height: 100vh;
            min-height: 100dvh;
            padding: var(--padding-slide-top) var(--padding-slide) var(--padding-slide-bottom);
            flex-direction: column;
            overflow-y: auto;
            overflow-x: hidden;
        }
        .slide.active { display: flex; }
        .slide.center {
            text-align: center;
            align-items: center;
            justify-content: center;
        }

        /* ── Typography ── */
        .section-label {
            font-size: var(--font-label);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--accent);
            margin-bottom: clamp(12px, 2vw, 20px);
        }
        .headline {
            font-size: var(--font-headline);
            font-weight: 700;
            letter-spacing: -0.03em;
            line-height: 1.1;
            color: var(--text-primary);
            margin-bottom: clamp(20px, 3vw, 36px);
        }
        .medium-headline {
            font-size: var(--font-medium-headline);
            font-weight: 700;
            letter-spacing: -0.02em;
            line-height: 1.15;
            color: var(--text-primary);
            margin-bottom: clamp(16px, 2.5vw, 28px);
        }
        .subhead {
            font-size: var(--font-subhead);
            font-weight: 400;
            color: var(--text-secondary);
            line-height: 1.4;
            max-width: 680px;
        }
        .body-text {
            font-size: var(--font-body);
            color: var(--text-secondary);
            line-height: 1.6;
            max-width: 740px;
        }
        .body-text strong { color: var(--text-primary); font-weight: 600; }
        .small-text {
            font-size: var(--font-small);
            color: var(--text-tertiary);
        }

        /* ── Grids ── */
        .grid-2 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(320px, 100%), 1fr));
            gap: var(--gap-grid);
            width: 100%;
        }
        .grid-3 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
            gap: var(--gap-grid);
            width: 100%;
        }
        .grid-4 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(220px, 100%), 1fr));
            gap: var(--gap-grid);
            width: 100%;
        }

        /* ── Cards ── */
        .card {
            background: var(--surface-1);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius);
            padding: clamp(16px, 3vw, 28px);
        }
        .card h3 {
            font-size: var(--font-body);
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: clamp(6px, 1vw, 10px);
        }
        .card p, .card li {
            font-size: var(--font-small);
            color: var(--text-secondary);
            line-height: 1.55;
        }
        .card ul {
            list-style: none;
            padding: 0;
        }
        .card ul li {
            padding: clamp(3px, 0.5vw, 5px) 0;
            padding-left: 1em;
            position: relative;
        }
        .card ul li::before {
            content: '';
            position: absolute;
            left: 0;
            top: clamp(10px, 1.2vw, 13px);
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--accent-dim);
        }

        /* ── Screenshots ── */
        .screenshot-container {
            width: 100%;
            max-width: 900px;
            margin: clamp(12px, 2vw, 24px) auto;
            border-radius: var(--radius);
            overflow: hidden;
            border: 1px solid var(--border-visible);
            box-shadow: 0 8px 40px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.05);
        }
        .screenshot-container img {
            width: 100%;
            height: auto;
            display: block;
        }
        .screenshot-caption {
            font-size: var(--font-small);
            color: var(--text-tertiary);
            text-align: center;
            margin-top: clamp(8px, 1.5vw, 14px);
        }

        .screenshot-with-text {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: clamp(24px, 4vw, 48px);
            align-items: start;
            width: 100%;
        }
        .screenshot-with-text .screenshot-container {
            max-width: 100%;
            margin: 0;
        }

        /* ── Transition List (Slide 10) ── */
        .transition-list {
            width: 100%;
            max-width: 860px;
        }
        .transition-row {
            display: flex;
            align-items: center;
            gap: clamp(12px, 2vw, 20px);
            padding: clamp(12px, 2vw, 18px) 0;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .transition-row:last-child { border-bottom: none; }
        .transition-before {
            font-size: var(--font-body);
            color: var(--text-tertiary);
            flex: 1;
            text-align: right;
        }
        .transition-arrow {
            font-size: var(--font-body);
            color: var(--accent);
            flex-shrink: 0;
            font-weight: 600;
        }
        .transition-after {
            font-size: var(--font-body);
            color: var(--text-primary);
            font-weight: 600;
            flex: 1;
        }

        /* ── Velocity Stats (Slide 11) ── */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(180px, 100%), 1fr));
            gap: var(--gap-grid);
            width: 100%;
            max-width: 960px;
        }
        .stat-card {
            background: var(--surface-1);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius);
            padding: clamp(20px, 3vw, 32px) clamp(16px, 2.5vw, 24px);
            text-align: center;
        }
        .stat-number {
            font-size: clamp(32px, 6vw, 56px);
            font-weight: 700;
            letter-spacing: -0.02em;
            color: var(--text-primary);
            line-height: 1;
            margin-bottom: clamp(4px, 0.8vw, 8px);
        }
        .stat-number .accent { color: var(--accent); }
        .stat-label {
            font-size: var(--font-small);
            color: var(--text-secondary);
            line-height: 1.3;
        }

        /* ── Contributor bar ── */
        .contributors {
            width: 100%;
            max-width: 960px;
            margin-top: clamp(20px, 3vw, 32px);
        }
        .contributors h4 {
            font-size: var(--font-small);
            font-weight: 600;
            color: var(--text-tertiary);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: clamp(10px, 1.5vw, 16px);
        }
        .contributor-bar {
            display: flex;
            height: clamp(6px, 1vw, 10px);
            border-radius: 999px;
            overflow: hidden;
            gap: 2px;
            margin-bottom: clamp(10px, 1.5vw, 16px);
        }
        .contributor-bar .seg { border-radius: 999px; }
        .contributor-names {
            display: flex;
            flex-wrap: wrap;
            gap: clamp(12px, 2vw, 24px);
        }
        .contributor-name {
            font-size: var(--font-small);
            color: var(--text-secondary);
        }
        .contributor-name .count {
            color: var(--text-tertiary);
            margin-left: 4px;
        }

        /* ── Badge ── */
        .badge {
            display: inline-block;
            font-size: var(--font-label);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding: clamp(4px, 0.6vw, 6px) clamp(10px, 1.5vw, 14px);
            border-radius: 999px;
            background: var(--accent-glow);
            color: var(--accent);
            border: 1px solid rgba(99, 102, 241, 0.3);
        }

        /* ── Code inline ── */
        code {
            font-family: 'SF Mono', 'Fira Code', 'JetBrains Mono', 'Courier New', monospace;
            font-size: 0.9em;
            background: var(--surface-2);
            padding: 2px 7px;
            border-radius: 5px;
            color: #a78bfa;
        }

        /* ── Highlight number ── */
        .highlight { color: var(--accent); }

        /* ── Navigation ── */
        .nav {
            position: fixed;
            bottom: clamp(18px, 3vw, 28px);
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: clamp(6px, 1vw, 10px);
            z-index: 100;
        }
        .nav-dot {
            width: clamp(8px, 1.2vw, 10px);
            height: clamp(8px, 1.2vw, 10px);
            border-radius: 50%;
            background: rgba(255,255,255,0.2);
            cursor: pointer;
            transition: all 0.25s ease;
            min-width: 8px;
            min-height: 8px;
        }
        .nav-dot:hover { background: rgba(255,255,255,0.4); }
        .nav-dot.active {
            background: var(--accent);
            box-shadow: 0 0 8px var(--accent-glow);
        }

        .slide-counter {
            position: fixed;
            bottom: clamp(18px, 3vw, 28px);
            right: clamp(20px, 3vw, 32px);
            font-size: var(--font-label);
            color: var(--text-tertiary);
            font-variant-numeric: tabular-nums;
            z-index: 100;
        }

        /* ── Responsive ── */
        @media (max-width: 768px) {
            .screenshot-with-text {
                grid-template-columns: 1fr;
            }
            .transition-row {
                flex-wrap: wrap;
                gap: clamp(4px, 1vw, 8px);
            }
            .transition-before, .transition-after {
                text-align: left;
                flex: unset;
            }
        }

        @media (max-height: 500px) and (orientation: landscape) {
            .slide {
                padding: 16px var(--padding-slide) 60px;
            }
            .slide.center {
                justify-content: flex-start;
                padding-top: 32px;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            .slide, .slide * {
                animation: none !important;
                transition: none !important;
            }
        }
    </style>
</head>
<body>

<!-- ════════════════════════════════════════════════════════
     SLIDE 1: TITLE
     ════════════════════════════════════════════════════════ -->
<div class="slide active center">
    <div class="badge" style="margin-bottom: clamp(20px, 3vw, 32px);">Week in Review</div>
    <h1 class="headline">amplifier-distro</h1>
    <p class="subhead" style="margin-bottom: clamp(16px, 2.5vw, 28px);">From architecturally complete prototype to daily-driver product</p>
    <div class="small-text" style="margin-bottom: clamp(12px, 2vw, 20px);">Feb 23 &ndash; Mar 4, 2026</div>
    <div class="small-text">Marc Goodner &middot; Samuel Lee &middot; Paul Payne</div>
</div>

<!-- ════════════════════════════════════════════════════════
     SLIDE 2: WHERE WE STARTED
     ════════════════════════════════════════════════════════ -->
<div class="slide">
    <div class="section-label">Context</div>
    <h2 class="headline">Where We Started</h2>
    <div class="body-text" style="margin-bottom: clamp(24px, 3.5vw, 36px);">
        amplifier-distro began as a prototype &mdash; an architecturally complete experience server
        with all major surfaces (web chat, voice, Slack, routines), a plugin architecture, CLI,
        and <strong>755 tests</strong>.
    </div>
    <div class="grid-2">
        <div class="card">
            <h3>Feb 28 Stakeholder Update</h3>
            <p>&ldquo;There&rsquo;s a working version you can install and run today.
               Treat this as something to form an opinion on, not a finished product.&rdquo;</p>
        </div>
        <div class="card">
            <h3>The Team&rsquo;s Focus Since</h3>
            <p>Take what works in demos and make it reliable for daily use.
               Close the gap between &ldquo;it runs&rdquo; and &ldquo;I use it every day.&rdquo;</p>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════════════════
     SLIDE 3: THE PRODUCT TODAY
     ════════════════════════════════════════════════════════ -->
<div class="slide">
    <div class="section-label">The Product Today</div>
    <h2 class="medium-headline">One command. Four surfaces. Shared runtime.</h2>
    <div class="screenshot-container">
        <img src="_screenshots/dashboard.png" alt="amplifier-distro dashboard showing Chat, Voice, Slack, and Settings app cards" loading="lazy">
    </div>
    <div class="screenshot-caption">
        <code>amp-distro</code> launches a multi-surface experience server &mdash;
        Chat, Voice, Slack, and Settings over a shared Amplifier runtime.
        Start a session in one surface, continue in another.
    </div>
</div>

<!-- ════════════════════════════════════════════════════════
     SLIDE 4: SECURE REMOTE ACCESS
     ════════════════════════════════════════════════════════ -->
<div class="slide">
    <div class="section-label">New This Week</div>
    <h2 class="headline">Secure Remote Access</h2>
    <div class="body-text" style="margin-bottom: clamp(20px, 3vw, 32px);">
        The prototype ran exclusively on localhost with no authentication.
        <code>amp-distro serve</code> now gives you secure remote access &mdash;
        the security layer required for any shared or team deployment.
    </div>
    <div class="grid-3">
        <div class="card">
            <h3>Auto-TLS Certificates</h3>
            <p>Self-signed certificates generated automatically on network binding. Detects and defers to Tailscale when active.</p>
        </div>
        <div class="card">
            <h3>PAM Authentication</h3>
            <p>System-level authentication with session tokens. Themed login page. No hardcoded credentials.</p>
        </div>
        <div class="card">
            <h3>Browser Security</h3>
            <p>CSRF protection, security headers, and session guards. Production-grade defaults out of the box.</p>
        </div>
    </div>
    <div class="body-text" style="margin-top: clamp(20px, 3vw, 32px);">
        <strong>Why it matters:</strong> prerequisite for every shared deployment scenario ahead.
    </div>
</div>

<!-- ════════════════════════════════════════════════════════
     SLIDE 5: CHAT
     ════════════════════════════════════════════════════════ -->
<div class="slide">
    <div class="section-label">Chat</div>
    <h2 class="medium-headline">From Demo to Daily Driver</h2>
    <div class="screenshot-with-text">
        <div class="screenshot-container">
            <img src="_screenshots/chat.png" alt="Chat client with session sidebar and active conversation" loading="lazy">
        </div>
        <div>
            <div class="card" style="margin-bottom: var(--gap-grid);">
                <h3>Reliability</h3>
                <ul>
                    <li>Event queue fanout: multiple browser tabs, no message loss</li>
                    <li>WebSocket reconnection survives phone locks, network blips, server restarts</li>
                </ul>
            </div>
            <div class="card" style="margin-bottom: var(--gap-grid);">
                <h3>Performance</h3>
                <ul>
                    <li>Session history: <strong>7s down to 0.5s</strong> (14x improvement)</li>
                </ul>
            </div>
            <div class="card">
                <h3>New Features</h3>
                <ul>
                    <li>Slash commands: /tools, /agents, /modes, /config</li>
                    <li>Inline session name editing</li>
                    <li>Pin-to-top for active sessions</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════════════════
     SLIDE 6: VOICE
     ════════════════════════════════════════════════════════ -->
<div class="slide">
    <div class="section-label">Voice</div>
    <h2 class="medium-headline">Voice with Delegation and Cross-Surface Continuity</h2>
    <div class="screenshot-with-text">
        <div>
            <div class="card" style="margin-bottom: var(--gap-grid);">
                <h3>Agent Delegation in Voice</h3>
                <p>Voice sessions can delegate to sub-agents. When delegation occurs, the voice app announces it audibly so the user knows work is happening in the background.</p>
            </div>
            <div class="card" style="margin-bottom: var(--gap-grid);">
                <h3>Visual Progress Indicators</h3>
                <p>Delegation progress is surfaced visually in real time &mdash; users see what sub-agents are doing, not just a silent wait.</p>
            </div>
            <div class="card">
                <h3>Voice to Chat Continuity</h3>
                <p>Open a voice conversation in the chat app to continue there. Start with your voice, switch to text when it makes sense.</p>
            </div>
        </div>
        <div class="screenshot-container">
            <img src="_screenshots/voice.png" alt="Voice interface with session list and audio controls" loading="lazy">
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════════════════
     SLIDE 7: SLACK
     ════════════════════════════════════════════════════════ -->
<div class="slide">
    <div class="section-label">Slack</div>
    <h2 class="medium-headline">From Functional to Pleasant</h2>
    <div class="screenshot-with-text">
        <div class="screenshot-container">
            <img src="_screenshots/slack.png" alt="Slack setup wizard showing 4-step installation flow" loading="lazy">
        </div>
        <div>
            <div class="card" style="margin-bottom: var(--gap-grid);">
                <h3>This Week</h3>
                <ul>
                    <li>Progress indicators with elapsed time during long operations</li>
                    <li>File downloads with sanitization and error messaging</li>
                    <li>Prompt enrichment: channel and user context added automatically</li>
                </ul>
            </div>
            <div class="card">
                <h3>Up Next</h3>
                <p>8 enhancement issues filed for the next sprint: DM support, reactions, multi-instance, watchdog, and more.</p>
            </div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════════════════
     SLIDE 8: THE SHIFT
     ════════════════════════════════════════════════════════ -->
<div class="slide">
    <div class="section-label">The Shift</div>
    <h2 class="headline">What Changed This Week</h2>
    <div class="transition-list">
        <div class="transition-row">
            <span class="transition-before">Localhost-only</span>
            <span class="transition-arrow">&rarr;</span>
            <span class="transition-after">Network-ready with TLS + auth</span>
        </div>
        <div class="transition-row">
            <span class="transition-before">Demo-reliable</span>
            <span class="transition-arrow">&rarr;</span>
            <span class="transition-after">Daily-driver reliable</span>
        </div>
        <div class="transition-row">
            <span class="transition-before">Preview API</span>
            <span class="transition-arrow">&rarr;</span>
            <span class="transition-after">Production API (Voice)</span>
        </div>
        <div class="transition-row">
            <span class="transition-before">Prototype theming</span>
            <span class="transition-arrow">&rarr;</span>
            <span class="transition-after">Product brand (withamplifier.com)</span>
        </div>
        <div class="transition-row">
            <span class="transition-before">Features exist</span>
            <span class="transition-arrow">&rarr;</span>
            <span class="transition-after">Features are pleasant</span>
        </div>
        <div class="transition-row">
            <span class="transition-before">Users trying it</span>
            <span class="transition-arrow">&rarr;</span>
            <span class="transition-after">Users giving structured feedback</span>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════════════════
     SLIDE 9: WHAT'S NEXT
     ════════════════════════════════════════════════════════ -->
<div class="slide">
    <div class="section-label">What&rsquo;s Next</div>
    <h2 class="headline">Coming Up</h2>
    <div class="grid-2">
        <div class="card">
            <h3>Installation Experience</h3>
            <p>Directional discussions underway about rethinking how we manage the distro installation. Syncing with Brian on lessons learned, incorporating Paul&rsquo;s learnings from Lakehouse. More specifics after in-person meetings this week.</p>
        </div>
        <div class="card">
            <h3>amplifierd (Amplifier Daemon)</h3>
            <p>Paul has made excellent progress. Coming into distro soon, and designed so others across the ecosystem can use it too.</p>
        </div>
        <div class="card">
            <h3>Slack as First-Class Surface</h3>
            <p>8 enhancement issues queued: DM support, emoji reactions, multi-instance, watchdog monitoring, and more.</p>
        </div>
        <div class="card">
            <h3>Quality &amp; Performance</h3>
            <p>User feedback backlog: structured UX gaps to close. Bundle pre-warming: PR open to eliminate cold-start latency.</p>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════════════════
     SLIDE 10: BY THE NUMBERS
     ════════════════════════════════════════════════════════ -->
<div class="slide">
    <div class="section-label">Velocity</div>
    <h2 class="headline">By the Numbers</h2>
    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-number">267</div>
            <div class="stat-label">Total commits<br>(235 non-merge)</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">50<span class="accent">+</span></div>
            <div class="stat-label">PRs merged</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">47</div>
            <div class="stat-label">Issues created<br>47 closed / 47 open</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">77.6<span class="accent">K</span></div>
            <div class="stat-label">Lines of code<br>across 196 files</div>
        </div>
    </div>
    <div class="contributors">
        <h4>Contributors</h4>
        <div class="contributor-bar">
            <div class="seg" style="flex: 105; background: var(--accent);"></div>
            <div class="seg" style="flex: 100; background: #a78bfa;"></div>
            <div class="seg" style="flex: 26; background: #c4b5fd;"></div>
            <div class="seg" style="flex: 1; background: var(--text-tertiary);"></div>
        </div>
        <div class="contributor-names">
            <span class="contributor-name" style="color: var(--accent);">Marc Goodner<span class="count">(105)</span></span>
            <span class="contributor-name" style="color: #a78bfa;">Samuel Lee<span class="count">(100)</span></span>
            <span class="contributor-name" style="color: #c4b5fd;">Paul Payne<span class="count">(26)</span></span>
            <span class="contributor-name">Brian Krabach<span class="count">(1)</span></span>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════════════════
     NAVIGATION
     ════════════════════════════════════════════════════════ -->
<div class="nav" id="nav"></div>
<div class="slide-counter" id="counter"></div>

<script>
    const slides = document.querySelectorAll('.slide');
    let currentSlide = 0;

    function showSlide(n) {
        slides[currentSlide].classList.remove('active');
        currentSlide = (n + slides.length) % slides.length;
        slides[currentSlide].classList.add('active');
        slides[currentSlide].scrollTop = 0;
        updateNav();
    }

    function updateNav() {
        const nav = document.getElementById('nav');
        const counter = document.getElementById('counter');
        nav.innerHTML = '';
        slides.forEach((_, i) => {
            const dot = document.createElement('div');
            dot.className = 'nav-dot' + (i === currentSlide ? ' active' : '');
            dot.onclick = (e) => { e.stopPropagation(); showSlide(i); };
            nav.appendChild(dot);
        });
        counter.textContent = (currentSlide + 1) + ' / ' + slides.length;
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); showSlide(currentSlide + 1); }
        if (e.key === 'ArrowLeft') { e.preventDefault(); showSlide(currentSlide - 1); }
    });

    document.addEventListener('click', (e) => {
        if (e.target.closest('.nav') || e.target.closest('a') || e.target.closest('code')) return;
        if (e.clientX > window.innerWidth / 2) showSlide(currentSlide + 1);
        else showSlide(currentSlide - 1);
    });

    let touchStartX = 0;
    let touchEndX = 0;
    const SWIPE_THRESHOLD = 50;

    document.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    document.addEventListener('touchend', (e) => {
        touchEndX = e.changedTouches[0].screenX;
        const diff = touchStartX - touchEndX;
        if (Math.abs(diff) > SWIPE_THRESHOLD) {
            if (diff > 0) showSlide(currentSlide + 1);
            else showSlide(currentSlide - 1);
        }
    }, { passive: true });

    updateNav();
</script>
</body>
</html>
